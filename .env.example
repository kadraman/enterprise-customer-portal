# Root environment variables used by docker-compose for backend runtime settings.
# Copy this file to .env in the repository root and set real values.

# Shared tenant ID used by frontend and backend runtime token validation.
ENTRA_TENANT_ID=<your-tenant-id>

# Frontend Entra App Registration
ENTRA_CLIENT_ID=<your-frontend-app-registration-client-id>
ENTRA_AUTHORITY=https://login.microsoftonline.com/<your-tenant-id>

# API scope - format: api://<backend-client-id>/access_as_user
ENTRA_API_SCOPES=api://<your-backend-client-id>/access_as_user

# Redirect URI (must match Azure app registration)
ENTRA_API_REDIRECT_URI=http://localhost:8080

# Optional popup callback page for loginPopup (recommended to avoid popup showing the full app)
ENTRA_POPUP_REDIRECT_URI=http://localhost:8080/auth-popup.html
